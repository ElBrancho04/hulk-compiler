type Point(x, y) {
    x = x;
    y = y;
    
    magnitude() => (self.x ^ 2 + self.y ^ 2) ^ 0.5;
}

type PolarPoint(r, theta) inherits Point {
    r = r;
    theta = theta;
}

function factorial(n) => if (n <= 1) 1 else n * factorial(n - 1);

function build_points(n) => [new Point(i, i * 2) | i in [1, 2, 3, 4, 5] if i < n];

let p = new PolarPoint(10, 0.78),
    points = build_points(4) in 
    if (p is Point) 
        for (pt in points)
            print(pt.magnitude())
    else 
        print("Error");